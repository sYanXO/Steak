generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum AccountStatus {
  ACTIVE
  SUSPENDED
}

enum MarketStatus {
  DRAFT
  OPEN
  CLOSED
  SETTLED
  VOID
}

enum MatchStatus {
  SCHEDULED
  LIVE
  COMPLETED
  CANCELLED
  ARCHIVED
}

enum LedgerEntryType {
  STARTER_GRANT
  STAKE_DEBIT
  SETTLEMENT_CREDIT
  SETTLEMENT_REVERSAL
  ADMIN_TOP_UP
  ADMIN_CORRECTION
}

enum StakeResult {
  PENDING
  WON
  LOST
  VOID
}

enum LeaderboardScope {
  GLOBAL
  GROUP
}

enum AdminActionType {
  MATCH_CREATED
  MATCH_UPDATED
  MARKET_CREATED
  MARKET_UPDATED
  MARKET_STATUS_CHANGED
  MARKET_SETTLED
  BALANCE_TOP_UP
  ACCOUNT_RECOVERY_RESOLVED
}

enum RecoveryRequestStatus {
  OPEN
  RESOLVED
  REJECTED
}

enum CredentialChangeType {
  EMAIL
  PASSWORD
}

model User {
  id            String          @id @default(cuid())
  email         String          @unique
  name          String?
  passwordHash  String?
  image         String?
  role          UserRole        @default(USER)
  status        AccountStatus   @default(ACTIVE)
  wallet        Wallet?
  stakes        Stake[]
  groupsOwned   Group[]         @relation("GroupOwner")
  memberships   GroupMember[]
  leaderboard   LeaderboardEntry[]
  adminActions  AdminActionLog[]
  ledgerEntries LedgerEntry[]   @relation("LedgerEntryActor")
  accounts      Account[]
  sessions      Session[]
  recoveryRequests AccountRecoveryRequest[]
  credentialChangeRequests CredentialChangeRequest[]
  lastEmailChangeAt DateTime?
  lastPasswordChangeAt DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

model Wallet {
  id        String        @id @default(cuid())
  userId    String        @unique
  balance   Int           @default(0)
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  entries   LedgerEntry[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model LedgerEntry {
  id              String          @id @default(cuid())
  walletId        String
  wallet          Wallet          @relation(fields: [walletId], references: [id], onDelete: Cascade)
  type            LedgerEntryType
  amountDelta     Int
  balanceAfter    Int
  reason          String
  relatedEntityId String?
  actorId         String?
  actor           User?           @relation("LedgerEntryActor", fields: [actorId], references: [id], onDelete: SetNull)
  createdAt       DateTime        @default(now())

  @@index([walletId, createdAt])
  @@index([type, createdAt])
}

model Match {
  id           String       @id @default(cuid())
  provider     String?
  providerMatchId String?   @unique
  title        String
  homeTeam     String
  awayTeam     String
  startsAt     DateTime
  status       MatchStatus  @default(SCHEDULED)
  tossWinner   String?
  tossDecision String?
  winnerTeam   String?
  completedAt  DateTime?
  lastSyncedAt DateTime?
  markets      Market[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([status, startsAt])
  @@index([provider, startsAt])
}

model Market {
  id                 String        @id @default(cuid())
  matchId            String
  match              Match         @relation(fields: [matchId], references: [id], onDelete: Cascade)
  type               String
  title              String
  status             MarketStatus  @default(DRAFT)
  opensAt            DateTime
  closesAt           DateTime
  settledAt          DateTime?
  settledOutcomeId   String?
  automationEnabled  Boolean       @default(false)
  autoCreated        Boolean       @default(false)
  automationKey      String?
  pricingMetadata    Json?
  outcomes           MarketOutcome[]
  oddsSnapshots      OutcomeOddsSnapshot[]
  stakes             Stake[]
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  @@index([status, closesAt])
  @@index([matchId, status])
  @@index([automationEnabled, status, opensAt])
  @@index([automationEnabled, status, closesAt])
  @@index([automationKey, status])
}

model MarketOutcome {
  id           String    @id @default(cuid())
  marketId     String
  market       Market    @relation(fields: [marketId], references: [id], onDelete: Cascade)
  label        String
  order        Int
  currentOdds  Decimal   @db.Decimal(10, 4)
  totalStaked  Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  stakes       Stake[]
  oddsSnapshots OutcomeOddsSnapshot[]

  @@unique([marketId, label])
}

model OutcomeOddsSnapshot {
  id          String        @id @default(cuid())
  marketId    String
  market      Market        @relation(fields: [marketId], references: [id], onDelete: Cascade)
  outcomeId   String
  outcome     MarketOutcome @relation(fields: [outcomeId], references: [id], onDelete: Cascade)
  oddsValue   Decimal       @db.Decimal(10, 4)
  totalStaked Int
  recordedAt  DateTime      @default(now())

  @@index([marketId, recordedAt])
  @@index([outcomeId, recordedAt])
}

model Stake {
  id                String      @id @default(cuid())
  userId            String
  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  marketId          String
  market            Market      @relation(fields: [marketId], references: [id], onDelete: Cascade)
  outcomeId         String
  outcome           MarketOutcome @relation(fields: [outcomeId], references: [id], onDelete: Restrict)
  amount            Int
  quotedOdds        Decimal     @db.Decimal(10, 4)
  payoutBasis       Decimal     @db.Decimal(12, 4)
  result            StakeResult @default(PENDING)
  payoutAmount      Int         @default(0)
  settledAt         DateTime?
  createdAt         DateTime    @default(now())

  @@unique([userId, marketId])
  @@index([marketId, result])
  @@index([userId, result, createdAt])
}

model Group {
  id           String        @id @default(cuid())
  name         String
  slug         String        @unique
  ownerId      String
  owner        User          @relation("GroupOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members      GroupMember[]
  leaderboard  LeaderboardEntry[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model GroupMember {
  id        String   @id @default(cuid())
  groupId   String
  userId    String
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([groupId, userId])
  @@index([groupId, createdAt])
}

model LeaderboardEntry {
  id          String           @id @default(cuid())
  scope       LeaderboardScope
  userId      String
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  groupId     String?
  group       Group?           @relation(fields: [groupId], references: [id], onDelete: Cascade)
  rank        Int?
  score       Int
  balance     Int
  seasonKey   String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([scope, rank, createdAt])
  @@index([groupId, scope, rank])
  @@index([userId, scope])
}

model AdminActionLog {
  id           String          @id @default(cuid())
  adminId      String
  admin        User            @relation(fields: [adminId], references: [id], onDelete: Cascade)
  actionType   AdminActionType
  targetType   String
  targetId     String
  reason       String
  metadata     Json?
  createdAt    DateTime        @default(now())

  @@index([actionType, createdAt])
  @@index([adminId, createdAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model AccountRecoveryRequest {
  id             String                @id @default(cuid())
  userId         String
  user           User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  currentEmail   String
  requestedEmail String
  reason         String
  status         RecoveryRequestStatus @default(OPEN)
  resolvedAt     DateTime?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  @@index([status, createdAt])
  @@index([userId, status])
}

model CredentialChangeRequest {
  id             String               @id @default(cuid())
  userId         String
  user           User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  type           CredentialChangeType
  targetEmail    String?
  passwordHash   String?
  otpCode        String
  expiresAt      DateTime
  verifiedAt     DateTime?
  createdAt      DateTime             @default(now())

  @@index([userId, type, verifiedAt])
  @@index([expiresAt])
}

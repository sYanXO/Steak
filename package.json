{
  "name": "stake-ipl",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "node --import tsx --test --test-concurrency=1 tests/**/*.test.ts",
    "test:e2e": "playwright test",
    "lint": "next lint",
    "db:setup": "prisma migrate dev && prisma db seed",
    "db:reset": "prisma migrate reset --force",
    "db:reset-demo": "tsx prisma/reset-demo.ts",
    "bootstrap:admin": "tsx prisma/bootstrap-admin.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "tsx prisma/seed.ts",
    "prisma:seed:local-demo": "SEED_PROFILE=local-demo tsx prisma/seed.ts",
    "prisma:seed:staging": "SEED_PROFILE=staging-demo tsx prisma/seed.ts",
    "prisma:seed:production-safe": "SEED_PROFILE=production-safe tsx prisma/seed.ts",
    "db:audit-request-constraints": "tsx prisma/audit-request-constraints.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@prisma/client": "^6.5.0",
    "@radix-ui/react-slot": "^1.1.2",
    "bcryptjs": "^3.0.2",
    "clsx": "^2.1.1",
    "lucide-react": "^0.483.0",
    "next": "^15.2.3",
    "next-auth": "^5.0.0-beta.25",
    "nodemailer": "^7.0.13",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.15.4",
    "tailwind-merge": "^3.0.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.0.17",
    "@types/node": "^22.13.10",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "postcss": "^8.5.3",
    "prisma": "^6.5.0",
    "tailwindcss": "^4.0.17",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
